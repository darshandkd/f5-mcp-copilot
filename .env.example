# ==============================================
# F5 MCP Copilot Server Configuration
# Copy this file to .env and fill in your values
# ==============================================

# Default device (loaded on startup)
F5_HOST=your-f5-hostname-or-ip
F5_USER=admin
F5_SSH_KEY=/path/to/your/ssh-key
# F5_PASSWORD=your-password    # Alternative to SSH key (use one or the other)
F5_PORT=22

# Additional named devices (uncomment and configure)
# Format: F5_DEVICE_{NAME}_{FIELD}
#
# F5_DEVICE_PROD_HOST=10.1.1.200
# F5_DEVICE_PROD_USER=admin
# F5_DEVICE_PROD_PASSWORD=your-password
# F5_DEVICE_PROD_PORT=22
#
# F5_DEVICE_LAB_HOST=192.168.1.50
# F5_DEVICE_LAB_USER=root
# F5_DEVICE_LAB_SSH_KEY=~/.ssh/lab_key

# Server Configuration
MCP_HOST=0.0.0.0
MCP_PORT=8080
MCP_API_KEY=generate-a-secure-random-key-here
